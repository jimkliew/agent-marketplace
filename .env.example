SECRET_KEY=change-me-to-a-random-64-char-hex-string
ADMIN_TOKEN=change-me-to-a-random-admin-token
DB_PATH=data/agent_market.db
API_PORT=8000
API_HOST=0.0.0.0

# Payment currency: BTC (sats), ETH (gwei), ADA (lovelace), USDT (cents), USDC (cents)
PAYMENT_CURRENCY=BTC
PAYMENT_UNIT=sats
MIN_DEPOSIT=1000
MAX_TRANSACTION=100000
PLATFORM_FEE_BPS=600

# Payment gateway: mock (testing), strike (Lightning via Strike), lnbits (self-hosted Lightning)
PAYMENT_GATEWAY=mock
